# Google Cloud
GCP_PROJECT_ID=301823798218
GCP_PROJECT_NAME=orderededge-groupware
GCP_REGION=europe-west2
GCP_ZONE=europe-west2-b

# Service Account (for Compute Engine, Drive, Sheets, Gmail)
GCP_SERVICE_ACCOUNT_JSON=/home/stu/.config/gcp/forge-ccd-service-account.json

# Sheets (VM Register)
# Create at: https://docs.google.com/spreadsheets
SHEETS_SPREADSHEET_ID=

# Drive (Evidence)
# Create folder and copy folder ID from URL
DRIVE_EVIDENCE_FOLDER_ID=

# Gmail (Notifications)
# OAuth2 client secrets from Google Cloud Console
# Enable Gmail API first: https://console.cloud.google.com/apis/library/gmail.googleapis.com
GMAIL_SENDER_EMAIL=stuharker@gmail.com
GMAIL_CLIENT_SECRETS=~/.config/gmail/client_secrets.json

# Logging
LOG_LEVEL=INFO
