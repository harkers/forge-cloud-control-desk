# Google Cloud
GCP_PROJECT_ID=301823798218
GCP_PROJECT_NAME=orderededge-groupware
GCP_REGION=europe-west2
GCP_ZONE=europe-west2-b

# Service Account (for Compute Engine, Sheets)
GCP_SERVICE_ACCOUNT_JSON=/home/stu/.config/gcp/forge-ccd-service-account.json

# Sheets (VM Register)
SHEETS_SPREADSHEET_ID=1-AA3fWiNEBxaygbV3oZ-naoCrLufAMmr468m6eDdkWE

# Drive (Evidence) - Shared Drive not available, using local folder
# Shared Drive creation requires enterprise Google Workspace admin privileges
# Evidence files are written locally and can be uploaded to Drive manually if needed
DRIVE_EVIDENCE_FOLDER_ID=/home/stu/.openclaw/workspace/projects/forge-cloud-control-desk/data/evidence

# Gmail (Notifications) - SKIPPED due to OAuth delegation requirements
# Service accounts cannot send emails via Gmail API without domain-wide delegation
# Local notifications are written to evidence folder instead
GMAIL_SENDER_EMAIL=stuharker@gmail.com

# Logging
LOG_LEVEL=INFO

